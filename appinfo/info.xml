<?xml version="1.0"?>
<info xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="https://apps.nextcloud.com/schema/apps/info.xsd">
    <id>codeinjector</id>
    <name>Code Injector</name>
    <summary>Inject custom HTML into every page head or body</summary>
    <description><![CDATA[Allows administrators to inject arbitrary HTML code into the `<head>` or `<body>` of every Nextcloud page.

Example use cases:
- Analytics and tracking snippets
- Tag management containers
- Customizations (e.g. styles)
]]></description>
    <version>1.0.0</version>
    <licence>AGPL-3.0-or-later</licence>
    <author homepage="https://github.com/zawias-pro">Paweł Zawiślak</author>
    <category>customization</category>
    <bugs>https://github.com/zawias-pro/nextcloud-code-inject/issues</bugs>
    <repository>https://github.com/zawias-pro/nextcloud-code-inject</repository>
    <dependencies>
        <php min-version="8.2"/>
        <nextcloud min-version="30" max-version="34"/>
    </dependencies>
    <settings>
        <admin>OCA\Codeinjector\Settings\AdminSettings</admin>
        <admin-section>OCA\Codeinjector\Sections\AdminSection</admin-section>
    </settings>
</info>
